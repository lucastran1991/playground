# Caddy reverse proxy for docker-compose stack
# Auto-HTTPS via Let's Encrypt when DOMAIN is a real hostname
# Set DOMAIN=localhost to disable HTTPS for local testing
#
# Service targets use compose service names (backend, frontend)
# resolvable via compose network DNS

{$DOMAIN:localhost} {
    # Backend API
    handle /api/* {
        reverse_proxy backend:8080
    }

    # Health check
    handle /health {
        reverse_proxy backend:8080
    }

    # Swagger docs (remove or protect in production)
    handle /swagger/* {
        reverse_proxy backend:8080
    }

    # Frontend (Next.js)
    handle {
        reverse_proxy frontend:3000
    }
}
